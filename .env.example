# ─────────────────────────────────────────────
# Hinarat – Required Environment Variables
# Copy this file to .env and fill in your values
# Add these same keys in Render dashboard → Environment
# ─────────────────────────────────────────────

# Supabase Project URL (from: Supabase → Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (from: Supabase → Settings → API → Project API Keys → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# Supabase Project ID (the subdomain of your Supabase URL)
VITE_SUPABASE_PROJECT_ID=your-project-id
